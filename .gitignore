cat > .gitignore << EOL
# Dependencies
node_modules/
.pnp/
.pnp.js

# Build outputs
.next/
out/
dist/
build/

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Backend uploads
backend/uploads/

# Documentation (optional - remove if you want to keep these)
*.md
DEPLOYMENT.md
PROJECT-COMPLETE.md
performance-demo.md
security-demo.md
docs/
/documentation
*.pdf
*.doc
*.docx

# Scripts (if these are just for local development)
scripts/
*.sh
*.bat

# Docker files (optional - keep if needed for deployment)
# docker-compose.yml
# nginx.conf
# Dockerfile
# *.yml

# Temporary files
*.tmp
*.temp
*.log
*.cache
EOL